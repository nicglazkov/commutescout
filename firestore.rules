rules_version = '2';

// The database is reached ONLY by this project's server via the
// service-account SDK, which bypasses these rules. No client (browser,
// mobile, anyone holding the public Firebase web API key) is ever
// allowed to read or write directly. Deployed to the cloud.firestore
// release; keep it deny-all.
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
